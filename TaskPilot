function addClass(){
  var name=document.getElementById('cl-name').value.trim();
  if(!name){toast2('⚠️ Enter class name');return;}
  var from=document.getElementById('cl-from').value;
  var to=document.getElementById('cl-to').value;
  if(t2m(to)<=t2m(from)){toast2('⚠️ End must be after start');return;}
  var days=getSel('cl-days');
  if(!days.length){toast2('⚠️ Pick days');return;}
  var room=document.getElementById('cl-room').value.trim();
  var cls={id:Date.now(),name:name,room:room,from:from,to:to,days:days,color:selClsColor};
  classesData.push(cls);
  autoBlockClass(cls);
  document.getElementById('cl-name').value='';
  document.getElementById('cl-room').value='';
  persist(); syncClasses(); renderClasses(); toast2('🎓 Class added + time blocked!');
}
function autoBlockClass(cls){
  cls.days.forEach(function(d){
    var already=blocks.some(function(b){
      return !b.fromClass && b.days.indexOf(d)>=0 && t2m(b.from)<=t2m(cls.from) && t2m(b.to)>=t2m(cls.to);
    });
    if(!already){
      blocks.push({id:Date.now()+Math.random(),label:cls.name,from:cls.from,to:cls.to,days:[d],fromClass:true,color:cls.color,clsId:cls.id});
    }
  });
}
function delClass(id){
  classesData=classesData.filter(function(c){return c.id!==id;});
  blocks=blocks.filter(function(b){return !(b.fromClass && b.clsId===id);});
  persist(); syncClasses(); renderClasses(); toast2('🗑️ Class removed');
}
function syncClasses(){
  blocks=blocks.filter(function(b){return !b.fromClass;});
  classesData.forEach(function(c){
    c.days.forEach(function(d){
      blocks.push({id:Date.now()+Math.random(),label:c.name,from:c.from,to:c.to,days:[d],fromClass:true,color:c.color,clsId:c.id});
    });
  });
  rBlocks();
}
