function updateDoneStats(){
  var pl=schedule.filter(function(s){return s.start>=0;});
  var uid=[]; pl.forEach(function(s){if(uid.indexOf(s.taskId)<0)uid.push(s.taskId);});
  var dn=uid.filter(function(id){return doneSet.has(id);}).length;
  var pct=uid.length?Math.round(dn/uid.length*100):0;
  document.getElementById('s-dn').textContent=dn;
  document.getElementById('s-dsub').textContent='of '+uid.length;
  document.getElementById('pg-lbl').textContent=dn+' / '+uid.length;
  document.getElementById('pg-pct').textContent=pct+'%';
  document.getElementById('pg-fill').style.width=pct+'%';
  var hd=uid.filter(function(id){return doneSet.has(id)&&tasks.some(function(t){return t.id===id&&t.pri==='high';});}).length;
  var ht=tasks.filter(function(t){return t.pri==='high';}).length;
  var sc=Math.min(100,Math.round(pct*.6+(ht?hd/ht*100*.4:pct*.4)));
  document.getElementById('s-score').textContent=sc;
  var arc=document.getElementById('s-arc');
  arc.style.strokeDashoffset=119-(119*sc/100);
