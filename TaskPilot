function t2m(t){ var p=t.split(':'); return parseInt(p[0])*60+parseInt(p[1]); }
function m2t(m){ var h=Math.floor(m/60)%24, mm=m%60; return (h<10?'0':'')+h+':'+(mm<10?'0':'')+mm; }
function f12(t){ var p=t.split(':'), h=parseInt(p[0]), m=parseInt(p[1]); return (h%12||12)+':'+(m<10?'0':'')+m+(h<12?'am':'pm'); }
function todayStr(){ return new Date().toISOString().slice(0,10); }
function dow(){ return new Date().getDay(); }
function daysUntil(ds){ var d=new Date(ds),n=new Date(); n.setHours(0,0,0,0); d.setHours(0,0,0,0); return Math.round((d-n)/86400000); }
function getSel(pid){ return Array.from(document.querySelectorAll('#'+pid+' .db.on')).map(function(b){return parseInt(b.dataset.d);}); }
function toast2(msg){ var e=document.getElementById('toast'); e.textContent=msg; e.classList.add('on'); setTimeout(function(){e.classList.remove('on');},2500); }

function persist(){
  localStorage.setItem('tp_tasks',JSON.stringify(tasks));
  localStorage.setItem('tp_blocks',JSON.stringify(blocks));
  localStorage.setItem('tp_cls',JSON.stringify(classesData));
  localStorage.setItem('tp_exams',JSON.stringify(exams));
  localStorage.setItem('tp_revs',JSON.stringify(reviews));
  localStorage.setItem('tp_saved',JSON.stringify(savedSchedules));
}
function load(){
  tasks   = JSON.parse(localStorage.getItem('tp_tasks') ||'[]');
  blocks  = JSON.parse(localStorage.getItem('tp_blocks')||'[]');
  classesData = JSON.parse(localStorage.getItem('tp_cls')  ||'[]');
  exams   = JSON.parse(localStorage.getItem('tp_exams')||'[]');
  reviews = JSON.parse(localStorage.getItem('tp_revs') ||'[]');
  savedSchedules = JSON.parse(localStorage.getItem('tp_saved')||'[]');
}

function go(v){
  document.querySelectorAll('.view').forEach(function(x){x.classList.remove('on');});
  document.querySelectorAll('.nt').forEach(function(x){x.classList.remove('on');});
  var el=document.getElementById('view-'+v);
  if(el) el.classList.add('on');
  var ids=['setup','classes','exams','dash','review','saved'];
  var idx=ids.indexOf(v);
  var tabs=document.querySelectorAll('.nt');
  if(tabs[idx]) tabs[idx].classList.add('on');
  if(v==='dash') renderDash();
  if(v==='saved') renderSaved();
  if(v==='classes') renderClasses();
  if(v==='exams') renderExams();
  if(v==='review') { renderReviews(); renderPerfLog(); }
}

