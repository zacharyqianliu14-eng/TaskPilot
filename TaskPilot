function doOCR(file){
  if(!file)return;
  var st=document.getElementById('o-st'), bw=document.getElementById('obw'), bar=document.getElementById('obar'), res=document.getElementById('o-res');
  st.textContent='🔍 Reading schedule…'; bw.style.display='block'; bar.style.width='0%'; res.innerHTML='';
  // Check if Tesseract loaded
  if(typeof Tesseract==='undefined'){
    st.textContent='📷 OCR library loading… try again in a moment.';
    // Lazy-load Tesseract
    var sc=document.createElement('script');
    sc.src='https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js';
    sc.onload=function(){ st.textContent='✅ Ready — please re-upload your image.'; };
    document.head.appendChild(sc);
    return;
  }
  Tesseract.createWorker('eng',1,{
    logger:function(m){ if(m.status==='recognizing text') bar.style.width=(m.progress*100)+'%'; }
  }).then(function(worker){
    return worker.recognize(file).then(function(result){
      worker.terminate();
      bar.style.width='100%';
      st.textContent='✅ Done — review below';
      parseOCR(result.data.text,res);
    });
  }).catch(function(err){
    st.textContent='❌ Failed — try a clearer image';
    console.error(err);
  });
}
function parseOCR(text,cont){
  var lines=text.split('\n').map(function(l){return l.trim();}).filter(function(l){return l.length>2;});
  var re=/(\d{1,2}):(\d{2})\s*(am|pm|AM|PM)?/g;
  var parsed=[];
  lines.forEach(function(line){
    var times=[], m;
    re.lastIndex=0;
    while((m=re.exec(line))!==null) times.push(m);
    if(times.length<1)return;
    var name=line.replace(/\d{1,2}:\d{2}\s*(am|pm)?[-–\s]*/gi,'').replace(/[^\w\s.,&()-]/g,'').trim();
    if(!name||name.length<2) name='Class';
    var fh=parseInt(times[0][1]), fm=parseInt(times[0][2]);
    var a0=(times[0][3]||'').toLowerCase();
    if(a0==='pm'&&fh<12) fh+=12;
    if(a0==='am'&&fh===12) fh=0;
    var from=(fh<10?'0':'')+fh+':'+(fm<10?'0':'')+fm;
    var to=(fh+1<10?'0':'')+(fh+1)+':'+(fm<10?'0':'')+fm;
    if(times.length>=2){
      var th=parseInt(times[1][1]), tm2=parseInt(times[1][2]);
      var a1=(times[1][3]||'').toLowerCase();
      if(a1==='pm'&&th<12) th+=12;
      if(a1==='am'&&th===12) th=0;
      to=(th<10?'0':'')+th+':'+(tm2<10?'0':'')+tm2;
    }
    if(t2m(to)>t2m(from)) parsed.push({name:name,from:from,to:to});
  });
  if(!parsed.length){cont.innerHTML='<div style="font-size:11px;color:var(--mu);padding:6px">No times detected. Try a clearer image or add manually.</div>';return;}
  var cols=['#3B6FD4','#D63B3B','#3BAD72','#E8952A','#7C3AED','#0EA5E9','#F72585'];
  var html='<div style="font-size:10px;font-weight:800;color:var(--mu);text-transform:uppercase;letter-spacing:.6px;margin-bottom:3px">Detected '+parsed.length+' item'+(parsed.length>1?'s':'')+' — edit if needed</div>';
  parsed.forEach(function(p,i){
    html+='<div id="or-'+i+'" style="display:flex;gap:4px;align-items:center;padding:6px;background:var(--bg);border:1.5px solid var(--bdr);border-radius:var(--rs)">'
      +'<div style="width:7px;height:7px;border-radius:50%;background:'+cols[i%cols.length]+';flex-shrink:0"></div>'
      +'<input type="text" value="'+esc(p.name)+'" id="on-'+i+'" style="flex:2;font-size:11px;padding:4px 7px">'
      +'<input type="time" value="'+p.from+'" id="of-'+i+'" style="width:80px;font-size:11px;padding:4px 7px">'
      +'<input type="time" value="'+p.to+'" id="ot-'+i+'" style="width:80px;font-size:11px;padding:4px 7px">'
      +'<button class="btn bg bsm" style="font-size:10px;padding:4px 8px" onclick="addOCRc('+i+',\''+cols[i%cols.length]+'\')">Add</button>'
      +'</div>';
  });
  cont.innerHTML=html;
}
function addOCRc(i,color){
  var nameEl=document.getElementById('on-'+i);
  var fromEl=document.getElementById('of-'+i);
  var toEl=document.getElementById('ot-'+i);
  if(!nameEl)return;
  var name=nameEl.value.trim()||'Class';
  var from=fromEl.value, to=toEl.value;
  var cls={id:Date.now()+i,name:name,room:'',from:from,to:to,days:[1,2,3,4,5],color:color};
  classesData.push(cls); autoBlockClass(cls);
  persist(); syncClasses(); renderClasses(); toast2('📚 "'+name+'" added!');
  var row=document.getElementById('or-'+i);
  if(row){row.style.opacity='.4';row.style.pointerEvents='none';}
}

