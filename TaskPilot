<script>
// ── Welcome particles ──
(function(){
  var c=document.getElementById('wp');
  for(var i=0;i<18;i++){
    var s=document.createElement('span');
    var z=Math.random()*60+18;
    s.style.cssText='width:'+z+'px;height:'+z+'px;left:'+(Math.random()*100)+'%;animation-duration:'+(Math.random()*7+5)+'s;animation-delay:'+(Math.random()*7)+'s';
    c.appendChild(s);
  }
})();

// ── Start button (safe, no external dep) ──
document.getElementById('startBtn').addEventListener('click', function(){
  var ws=document.getElementById('ws');
  ws.style.transition='opacity .5s, transform .5s';
  ws.style.opacity='0';
  ws.style.transform='scale(1.04)';
  setTimeout(function(){
    ws.style.display='none';
    document.getElementById('app').style.display='block';
    detectHoliday();
    init();
    reqNotif();
  }, 480);
});

// ── Holiday detection ──
function detectHoliday(){
  var n=new Date(), m=n.getMonth()+1, d=n.getDate();
  var ov=document.getElementById('hov');
  var theme=null;
  if(m===12&&d>=20&&d<=26) theme='xmas';
  if((m===12&&d===31)||(m===1&&d===1)) theme='ny';
  if((m===1&&d>=25)||(m===2&&d<=22)) theme='cny';

  if(theme==='xmas'){
    document.body.classList.add('xmas');
    for(var i=0;i<22;i++){
      var e=document.createElement('div');
      e.className='sf';
      e.textContent=['❄','❅','✦','·'][i%4];
      e.style.cssText='left:'+(Math.random()*100)+'%;font-size:'+(Math.random()*11+7)+'px;color:rgba(255,255,255,.85);animation-duration:'+(Math.random()*7+4)+'s;animation-delay:'+(Math.random()*8)+'s';
      ov.appendChild(e);
    }
    var b=document.createElement('div');b.className='hbadge';b.style.cssText='background:rgba(178,34,34,.85);color:#fff;';b.textContent='🎄 Merry Christmas!';ov.appendChild(b);
  }
  if(theme==='cny'){
    document.body.classList.add('cny');
    ['🏮','🧧','🐉','🏮','🧨'].forEach(function(ic,i){
      var e=document.createElement('div');e.className='ln';e.textContent=ic;
      e.style.cssText='left:'+(8+i*21)+'%;font-size:'+(28+Math.random()*10)+'px;animation-duration:'+(2+Math.random()*2)+'s;animation-delay:'+(i*.3)+'s';
      ov.appendChild(e);
    });
    var b=document.createElement('div');b.className='hbadge';b.style.cssText='background:rgba(192,57,43,.9);color:#FFD700;';b.textContent='🧧 新年快乐 Happy New Year!';ov.appendChild(b);
  }
  if(theme==='ny'){
    document.body.classList.add('ny');
    var cols=['#FFD700','#FF6B6B','#4ECDC4','#A8E6CF','#FFE66D','#FF8B94'];
    setInterval(function(){
      var e=document.createElement('div');e.className='fw';
      e.style.cssText='left:'+(10+Math.random()*80)+'%;top:'+(10+Math.random()*50)+'%;background:'+cols[Math.floor(Math.random()*cols.length)];
      ov.appendChild(e);setTimeout(function(){e.remove();},850);
    },520);
    var b=document.createElement('div');b.className='hbadge';b.style.cssText='background:rgba(0,0,0,.7);color:#FFD700;';b.textContent='🎆 Happy New Year!';ov.appendChild(b);
  }
}

// ── Notifications ──
function reqNotif(){
  if('Notification' in window && Notification.permission==='default') Notification.requestPermission();
}
function sendNotif(title,body){
  if('Notification' in window && Notification.permission==='granted'){
    try{ new Notification(title,{body:body}); }catch(e){}
  }
}

