function rTimeline(){
  var sh=parseInt((document.getElementById('s-start').value||'07:00').split(':')[0]);
  var eh=parseInt((document.getElementById('s-end').value||'23:00').split(':')[0]);
  var pl=schedule.filter(function(s){return s.start>=0;}), d=dow();
  var br=[];
  blocks.forEach(function(b){
    if(noSchool&&b.fromClass)return;
    if(b.days.indexOf(d)<0)return;
    var f=t2m(b.from), t2=t2m(b.to);
    if(t2<f) t2=1440;
    br.push({label:b.label,f:f,t:Math.min(t2,1440)});
  });
  var priClass={high:'s-high',med:'s-med',low:'s-low'};
  var priLabel={high:'High',med:'Med',low:'Low'};
  var priColor={high:'var(--hi)',med:'var(--me)',low:'var(--lo)'};
  var html='';
  for(var h=sh;h<=eh;h++){
    var hb=pl.filter(function(s){return Math.floor(s.start/60)===h;});
    var busy=null;
    for(var bi=0;bi<br.length;bi++){if(h*60>=br[bi].f&&h*60<br[bi].t){busy=br[bi];break;}}
    var bh=hb.map(function(s){
      var idx2=schedule.indexOf(s);
      var isActive=timerTaskIdx===idx2;
      var isDone=doneSet.has(s.taskId);
      var partTxt=s.total>1?' ('+s.part+'/'+s.total+')':'';
      var timerBtn=isDone
        ? '<span style="font-size:10px;color:var(--lo)">✅</span>'
        : '<button onclick="event.stopPropagation();startTimerFor('+idx2+')" style="background:var(--ac);color:#fff;border:none;border-radius:20px;padding:2px 7px;font-size:9px;font-weight:700;cursor:pointer">▶</button>';
      return '<div class="sb '+priClass[s.pri]+'" draggable="true" data-idx="'+idx2+'" ondragstart="dsS(event,this)" ondragend="dsE(event,this)"'+(isActive?' style="box-shadow:0 0 0 2px var(--ac)"':'')+'>'
        +'<div style="display:flex;align-items:center;gap:6px"><div class="sbn">'+esc(s.name)+partTxt+'</div>'+timerBtn+'</div>'
        +'<div class="sbt">'+f12(m2t(s.start))+'–'+f12(m2t(s.end))+'</div>'
        +'<span class="sbtg" style="background:'+priColor[s.pri]+'22;color:'+priColor[s.pri]+'">'+priLabel[s.pri]+'</span>'
        +'</div>';
    }).join('');
    html+='<div class="tlhr" data-h="'+h+'" ondragover="dsO(event,this)" ondragleave="dsL(event,this)" ondrop="dsDr(event,this)">'
      +'<div class="tllbl">'+(h%12||12)+(h<12?'am':'pm')+'</div>'
      +'<div class="tlct">'+(busy&&!hb.length?'<div class="sb s-busy">🚫 '+esc(busy.label)+'</div>':'')
      +bh+'</div></div>';
  }
  document.getElementById('tl-in').innerHTML=html;
}
function rCalDay(){
  var n=new Date();
  var sh=parseInt((document.getElementById('s-start').value||'07:00').split(':')[0]);
  var eh=parseInt((document.getElementById('s-end').value||'23:00').split(':')[0]);
  var pl=schedule.filter(function(s){return s.start>=0;});
  var pc={high:'var(--hbg)',med:'var(--mbg)',low:'var(--lbg)'};
  var pf={high:'#7a1a1a',med:'#7a4010',low:'#1a5c35'};
  var rows='';
  for(var h=sh;h<=eh;h++){
    var ev=pl.filter(function(s){return Math.floor(s.start/60)===h;});
    var evHtml=ev.map(function(s){
      var pt=s.total>1?' ('+s.part+'/'+s.total+')':'';
      return '<div class="cev" style="background:'+pc[s.pri]+';color:'+pf[s.pri]+'">'+esc(s.name)+pt+'<span style="font-size:9px;opacity:.65;margin-left:5px">'+f12(m2t(s.start))+'</span></div>';
    }).join('');
    rows+='<div class="ctr"><div class="ctlbl">'+(h%12||12)+(h<12?'am':'pm')+'</div><div class="ctcell">'+evHtml+'</div></div>';
  }
  document.getElementById('cal-wrap').innerHTML='<div class="calhdr"><span style="font-family:\'Playfair Display\',serif;font-size:14px">'+n.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'})+'</span><span style="font-size:10px;color:var(--mu)">'+pl.length+' blocks</span></div><div class="calbdy">'+rows+'</div>';
}
function renderChecklist(){
  var pl=schedule.filter(function(s){return s.start>=0;});
  var uid=[]; pl.forEach(function(s){if(uid.indexOf(s.taskId)<0)uid.push(s.taskId);});
  var el=document.getElementById('tplist');
  if(!uid.length){el.innerHTML='<div class="emp"><div class="ei">📋</div><h3>No tasks</h3><p>Generate a schedule first.</p></div>';return;}
  var pc={high:'var(--hbg)',med:'var(--mbg)',low:'var(--lbg)'};
  var pf={high:'var(--hi)',med:'#b36010',low:'var(--lo)'};
  el.innerHTML=uid.map(function(id){
    var t=null; for(var i=0;i<tasks.length;i++){if(tasks[i].id===id){t=tasks[i];break;}}
    if(!t)return'';
    var dn=doneSet.has(id);
    return '<div class="tpi'+(dn?' dn':'')+'" onclick="toggleDone('+id+')">'
      +'<div class="tpck">'+(dn?'✓':'')+'</div>'
      +'<div class="tpn">'+esc(t.name)+'</div>'
      +'<span style="font-size:9px;font-weight:800;padding:2px 6px;border-radius:3px;background:'+pc[t.pri]+';color:'+pf[t.pri]+'">'+t.pri+'</span>'
      +'</div>';
  }).join('');
}
function toggleDone(id){ if(doneSet.has(id))doneSet.delete(id);else doneSet.add(id); updateDoneStats(); renderChecklist(); rTimeline(); }
function renderTips(){
  var pl=schedule.filter(function(s){return s.start>=0;});
  var tips=[];
  var hc=pl.filter(function(s){return s.pri==='high';}).length;
  if(hc) tips.push('🔥 '+hc+' high-priority block'+(hc>1?'s':'')+' today — tackle these first!');
  var hrs=(pl.reduce(function(s,c){return s+c.dur;},0)/60).toFixed(1);
  if(parseFloat(hrs)>6) tips.push('💪 '+hrs+'hrs scheduled. Take regular breaks!');
  if(noSchool) tips.push('🏖️ No school today — enjoy the extra time!');
  var ue=exams.filter(function(e){var du=daysUntil(e.date);return du<=3&&du>=0;});
  if(ue.length) tips.push('🧪 '+ue[0].name+' in '+daysUntil(ue[0].date)+' day'+(daysUntil(ue[0].date)!==1?'s':'')+'. Review today!');
  tips.push('📵 Silence notifications during focus blocks.');
  document.getElementById('tips').innerHTML=tips.map(function(t){return '<div class="tipc">'+t+'</div>';}).join('');
}

// ── Drag & Drop ──
function dsS(e,el){ dragIdx=parseInt(el.dataset.idx); el.classList.add('dragging'); e.dataTransfer.effectAllowed='move'; }
function dsE(e,el){ el.classList.remove('dragging'); document.querySelectorAll('.tlhr').forEach(function(h){h.classList.remove('dov');}); dragIdx=null; }
function dsO(e,r){ e.preventDefault(); r.classList.add('dov'); }
function dsL(e,r){ r.classList.remove('dov'); }
function dsDr(e,r){
  e.preventDefault(); r.classList.remove('dov');
  if(dragIdx===null)return;
  var h=parseInt(r.dataset.h);
  var item=schedule[dragIdx];
  if(!item)return;
  schedule[dragIdx]=Object.assign({},item,{start:h*60,end:h*60+item.dur});
  rTimeline(); toast2('📌 Moved!');
}

// ── Daily Review ──
function selMood(btn){ document.querySelectorAll('.mood-btn').forEach(function(b){b.classList.remove('on');}); btn.classList.add('on'); currMood=btn.dataset.m; }
function saveReview(){
  var wins=document.getElementById('rev-win').value.trim();
  var hard=document.getElementById('rev-hard').value.trim();
  var tmrw=document.getElementById('rev-tmrw').value.trim();
  var prod=parseInt(document.getElementById('rev-prod').value)||0;
  if(!wins&&!hard&&!tmrw){toast2('⚠️ Write something first');return;}
  var pl=schedule.filter(function(s){return s.start>=0;});
  var uid=[]; pl.forEach(function(s){if(uid.indexOf(s.taskId)<0)uid.push(s.taskId);});
  var dn=uid.filter(function(id){return doneSet.has(id);}).length;
  reviews.unshift({
    id:Date.now(),date:todayStr(),mood:currMood,
    wins:wins,hard:hard,tmrw:tmrw,prod:prod,
    tasksTotal:uid.length,tasksDone:dn,
    perf:JSON.parse(JSON.stringify(perfLog))
  });
  persist();
  ['rev-win','rev-hard','rev-tmrw','rev-prod'].forEach(function(id){document.getElementById(id).value='';});
  document.querySelectorAll('.mood-btn').forEach(function(b){b.classList.remove('on');});
  renderReviews(); toast2('📝 Review saved!');
}
function delReview(id){ reviews=reviews.filter(function(r){return r.id!==id;}); persist(); renderReviews(); }
function renderReviews(){
  var el=document.getElementById('rev-list');
  if(!reviews.length){el.innerHTML='<div class="emp"><div class="ei">📝</div><h3>No entries yet</h3><p>Write your first daily review.</p></div>';return;}
  el.innerHTML=reviews.map(function(r){
    var perfHtml='';
    if(r.perf&&r.perf.length){
      var fast=r.perf.filter(function(p){return p.type==='fast';}).length;
      var slow=r.perf.filter(function(p){return p.type==='slow'||p.type==='over';}).length;
      var on=r.perf.filter(function(p){return p.type==='on';}).length;
      perfHtml='<div style="margin-top:7px;padding:7px 9px;background:var(--s2);border-radius:var(--rs);font-size:10px">'
        +'<div style="font-weight:800;color:var(--mu);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px">⏱ Task Timing</div>'
        +'<div style="display:flex;gap:8px;flex-wrap:wrap;">'
        +(fast?'<span style="color:var(--lo);font-weight:700">🚀 '+fast+' early</span>':'')
        +(on?'<span style="color:var(--ac);font-weight:700">✅ '+on+' on-time</span>':'')
        +(slow?'<span style="color:var(--hi);font-weight:700">🐢 '+slow+' over</span>':'')
        +'</div>'
        +r.perf.map(function(p){
          var col=p.type==='fast'?'var(--lo)':p.type==='over'||p.type==='slow'?'var(--hi)':'var(--ac)';
          var diff=p.type==='fast'?'-'+Math.abs(p.diff)+'min':p.type!=='on'?'+'+p.diff+'min':'±0';
          return '<div style="display:flex;justify-content:space-between;margin-top:3px;font-size:10px"><span style="color:var(--tx)">'+esc(p.name)+'</span><span style="color:'+col+';font-weight:700">'+p.actual+'min (est '+p.estimated+'min, '+diff+')</span></div>';
        }).join('')
        +'</div>';
    }
    return '<div class="rev-entry">'
      +'<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px">'
      +'<span class="rev-date-lbl">'+r.date+'</span>'
      +'<div style="display:flex;align-items:center;gap:6px"><span style="font-size:16px">'+r.mood+'</span><button class="xbtn" onclick="delReview('+r.id+')">✕</button></div>'
      +'</div>'
      +(r.wins?'<div class="rev-txt">🏆 <strong>Wins:</strong> '+esc(r.wins)+'</div>':'')
      +(r.hard?'<div class="rev-txt">💡 <strong>Challenges:</strong> '+esc(r.hard)+'</div>':'')
      +(r.tmrw?'<div class="rev-txt">🎯 <strong>Tomorrow:</strong> '+esc(r.tmrw)+'</div>':'')
      +'<div class="rev-stats">'
      +(r.prod?'<span class="rev-stat">⚡ Productivity: '+r.prod+'/10</span>':'')
      +(r.tasksTotal?'<span class="rev-stat">✅ '+r.tasksDone+'/'+r.tasksTotal+' tasks</span>':'')
      +'</div>'
      +perfHtml
      +'</div>';
  }).join('');
}
function renderPerfLogOnReviewTab(){
  // Also update the perf log card when navigating to review
  renderPerfLog();
}

// ── Save/Load ──
function saveSchedule(){
  if(!schedule.length){toast2('⚠️ Nothing to save');return;}
  var name=new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
  savedSchedules.unshift({id:Date.now(),name:name,tasks:JSON.parse(JSON.stringify(tasks)),schedule:JSON.parse(JSON.stringify(schedule))});
  persist(); toast2('💾 Saved!');
}
function renderSaved(){
  var el=document.getElementById('saved-list');
  if(!savedSchedules.length){el.innerHTML='<div class="emp"><div class="ei">💾</div><h3>No saves</h3><p>Generate a schedule and hit Save.</p></div>';return;}
  el.innerHTML=savedSchedules.map(function(s,i){
    var placed=s.schedule.filter(function(x){return x.start>=0;}).length;
    return '<div class="svdi" onclick="loadSaved('+i+')">'
      +'<span style="font-size:17px">📅</span>'
      +'<div style="flex:1"><div style="font-weight:700;font-size:13px">'+esc(s.name)+'</div><div style="font-size:10px;color:var(--mu)">'+s.tasks.length+' tasks · '+placed+' blocks</div></div>'
      +'<button class="btn bd bsm" onclick="event.stopPropagation();delSaved('+i+')">Delete</button>'
      +'</div>';
  }).join('');
}
function loadSaved(i){ var s=savedSchedules[i]; tasks=s.tasks; schedule=s.schedule; doneSet=new Set(); rTasks(); uSum(); go('dash'); toast2('📅 Loaded!'); }
function delSaved(i){ savedSchedules.splice(i,1); persist(); renderSaved(); }

