function rTimetable(){
  var el=document.getElementById('ttg');
  if(!classesData.length){el.innerHTML='<div style="grid-column:1/-1;padding:24px;text-align:center;color:var(--mu);font-size:12px">No classes yet</div>';return;}
  var mn=7,mx=18;
  classesData.forEach(function(c){ mn=Math.min(mn,Math.floor(t2m(c.from)/60)); mx=Math.max(mx,Math.ceil(t2m(c.to)/60)); });
  var dn=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'], td=dow();
  var h='<div class="tth"></div>';
  dn.forEach(function(d,i){ h+='<div class="tth" style="'+(i===td?'color:var(--ac);border-bottom:2px solid var(--ac)':'')+'">'+d+'</div>'; });
