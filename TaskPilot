// ── Scheduler ──
function generateSchedule(regen){
  if(!tasks.length){toast2('⚠️ Add at least one task');return;}
  var sm=t2m(document.getElementById('s-start').value||'07:00');
  var em=t2m(document.getElementById('s-end').value||'23:00');
  var brk=parseInt(document.getElementById('s-brk').value)||10;
  var chk=parseInt(document.getElementById('s-chunk').value)||90;
  var d=dow();
  var busy=[];
  blocks.forEach(function(b){
    if(noSchool&&b.fromClass)return;
    if(b.days.indexOf(d)<0)return;
    var f=t2m(b.from), t2=t2m(b.to);
    if(t2<f) t2+=1440;
    busy.push({f:f,t:t2});
  });
  function free(s,dur){ var e=s+dur; for(var i=0;i<busy.length;i++){if(s<busy[i].t&&e>busy[i].f)return false;} return true; }
  var ord={high:0,med:1,low:2};
  var sorted=[].concat(tasks).sort(function(a,b){
    if(ord[a.pri]!==ord[b.pri])return ord[a.pri]-ord[b.pri];
    if(a.dead&&b.dead)return a.dead.localeCompare(b.dead);
    if(a.dead)return -1; if(b.dead)return 1; return 0;
  });
  var chunks=[];
  sorted.forEach(function(t){
    var rem=t.dur, part=1, tot=Math.ceil(t.dur/chk);
    while(rem>0){ chunks.push({taskId:t.id,name:t.name,pri:t.pri,dead:t.dead,dur:Math.min(rem,chk),part:part,total:tot}); rem-=chk; part++; }
  });
  schedule=[]; var cur=sm;
  chunks.forEach(function(c){
    var ok=false, att=0;
    while(!ok&&cur<em&&att<300){
      att++;
      if(cur+c.dur>em)break;
      if(free(cur,c.dur)){schedule.push({taskId:c.taskId,name:c.name,pri:c.pri,dead:c.dead,dur:c.dur,part:c.part,total:c.total,start:cur,end:cur+c.dur});cur+=c.dur+brk;ok=true;}
      else cur+=5;
    }
    if(!ok) schedule.push({taskId:c.taskId,name:c.name,pri:c.pri,dead:c.dead,dur:c.dur,part:c.part,total:c.total,start:-1,end:-1,overflow:true});
  });
  doneSet=new Set();
  perfLog=[];
  schedNotifs();
  go('dash');
  toast2('✈ Schedule ready!');
}

function replanFrom(fromMin, extraMin){
  // extraMin can be positive (overtime → shift later) or negative (finished early → shift earlier)
  var minStart = fromMin + (extraMin < 0 ? extraMin : 0); // floor: don't go before fromMin when saving time
  schedule = schedule.map(function(s){
    if(s.start >= fromMin && !doneSet.has(s.taskId)){
      var newStart = Math.max(0, s.start + extraMin);
      return Object.assign({}, s, {start: newStart, end: newStart + s.dur});
    }
    return s;
  });
  schedNotifs();
  renderDash();
  if(extraMin > 0)      toast2('🔄 Replanned — tasks shifted +'+extraMin+'min');
  else if(extraMin < 0) toast2('🚀 Replanned — tasks shifted '+extraMin+'min earlier!');
}

// ── Notifications scheduling ──
function schedNotifs(){
  notifTimers.forEach(function(id){clearTimeout(id);});
  notifTimers=[];
  var now=new Date();
  var base=new Date(); base.setHours(0,0,0,0);
  schedule.filter(function(s){return s.start>=0;}).forEach(function(s,i){
    var st=new Date(base.getTime()+s.start*60000);
    var ms=st-now;
    if(ms>0&&ms<86400000){
      var id=setTimeout(function(){
        sendNotif('⏱ Starting: '+s.name,'Duration: '+s.dur+'min · '+f12(m2t(s.start))+'–'+f12(m2t(s.end)));
        var idx=schedule.indexOf(s);
        startTimerFor(idx);
      },ms);
      notifTimers.push(id);
    }
  });
}

// ── Timer ──
function startDay(){
  var placed=schedule.filter(function(s){return s.start>=0&&!doneSet.has(s.taskId);});
  if(!placed.length){toast2('⚠️ No tasks to start');return;}
  startTimerFor(schedule.indexOf(placed[0]));
  toast2('▶ Timer started!');
}

function startTimerFor(idx){
  if(idx<0||idx>=schedule.length)return;
  stopTimer(); stopBreak();
  timerTaskIdx=idx;
  timerDur=schedule[idx].dur*60;
  timerElapsed=0;
  timerPaused=false;
  timerOvertimeMarked=false;
  var s=schedule[idx];
  var nm=s.name+(s.total>1?' ('+s.part+'/'+s.total+')':'');
  document.getElementById('tb-name').textContent='⏱ '+nm;
  document.getElementById('tb-clock').className='tb-clock';
  document.getElementById('tb-fill').className='tb-fill';
  document.getElementById('tb-overtime').className='tb-overtime'; // hidden
  document.getElementById('tb-status').textContent='WORKING';
  document.getElementById('tb-status').style.background='var(--acl)';
  document.getElementById('tb-status').style.color='var(--ac)';
  document.getElementById('tb-pause-btn').textContent='⏸ Pause';
  document.getElementById('timerbar').classList.add('on');
  document.getElementById('timerbar').classList.remove('break-mode');
  timerInterval=setInterval(tickTimer,1000);
  sendNotif('⏱ Starting: '+nm,'Estimated: '+s.dur+'min');
}

function tickTimer(){
  if(timerPaused) return;
  timerElapsed++;
  var over=timerElapsed>timerDur;
  var display=over?timerElapsed-timerDur:timerDur-timerElapsed;
  var mm=Math.floor(display/60), ss=display%60;
  var clk=document.getElementById('tb-clock');
  clk.textContent=(over?'+':'')+(mm<10?'0':'')+mm+':'+(ss<10?'0':'')+ss;
  clk.className='tb-clock'+(over?' over':'');
  var pct=Math.min((timerElapsed/timerDur)*100,100);
  var fill=document.getElementById('tb-fill');
  fill.style.width=pct+'%';
  fill.className='tb-fill'+(over?' over':'');
  // Show overtime badge once we go over
  if(over){
    var otEl=document.getElementById('tb-overtime');
    var ot=timerElapsed-timerDur;
    var om=Math.floor(ot/60), os=ot%60;
    otEl.textContent='+'+(om<10?'0':'')+om+':'+(os<10?'0':'')+os+' over';
    otEl.className='tb-overtime show';
  }
  // 5 min warning
  if(timerDur-timerElapsed===300) sendNotif('⚠️ 5 min left',schedule[timerTaskIdx]?schedule[timerTaskIdx].name:'');
  // Time's up notification (once, exactly at 0)
  if(timerElapsed===timerDur) sendNotif('✅ Time is up!',schedule[timerTaskIdx]?schedule[timerTaskIdx].name+' — hit Done when finished':'');
}

function stopTimer(){
  if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
}

function pauseTimer(){
  var btn=document.getElementById('tb-pause-btn');
  if(timerPaused){
    timerPaused=false;
    btn.textContent='⏸ Pause';
    document.getElementById('tb-status').textContent='WORKING';
    document.getElementById('tb-status').style.background='var(--acl)';
    document.getElementById('tb-status').style.color='var(--ac)';
    document.getElementById('tb-clock').className='tb-clock'+(timerElapsed>timerDur?' over':'');
    toast2('▶ Resumed');
  } else {
    timerPaused=true;
    btn.textContent='▶ Resume';
    document.getElementById('tb-status').textContent='PAUSED';
    document.getElementById('tb-status').style.background='var(--mbg)';
    document.getElementById('tb-status').style.color='var(--me)';
    document.getElementById('tb-clock').className='tb-clock paused';
    toast2('⏸ Paused');
  }
}

function overTime(){
  // Mark overtime at current moment — records it and resets to "extra counting"
  if(timerElapsed<=timerDur){toast2('Not over time yet!');return;}
  if(timerOvertimeMarked){toast2('Overtime already marked');return;}
  timerOvertimeMarked=true;
  var extraSec=timerElapsed-timerDur;
  var extraMin=Math.ceil(extraSec/60);
  if(schedule[timerTaskIdx]){
    var s=schedule[timerTaskIdx];
    var actualMin=Math.round(timerElapsed/60);
    recordPerf(s, actualMin, extraMin, 'over');
    replanFrom(s.end, extraMin);
  }
  toast2('⏰ +'+extraMin+'min overtime recorded & schedule replanned');
}

function finishTask(){
  stopTimer();
  var bar = document.getElementById('timerbar');
  var prevIdx = timerTaskIdx;

  if(timerTaskIdx >= 0 && schedule[timerTaskIdx]){
    var s = schedule[timerTaskIdx];
    var actualMin = Math.max(1, Math.round(timerElapsed / 60));
    var estMin = s.dur;
    var diff = actualMin - estMin;
    var type = diff < -1 ? 'fast' : (diff > 1 ? 'slow' : 'on');

    // Only record perf if overtime wasn't already marked (overtime already recorded it)
    if(!timerOvertimeMarked){
      recordPerf(s, actualMin, diff, type);
    }

    doneSet.add(s.taskId);
    schedule[timerTaskIdx] = Object.assign({}, s, {actualDur: actualMin});

    // If finished significantly faster and no overtime, shift future tasks earlier
    if(diff < -2 && !timerOvertimeMarked){
      replanFrom(s.end, diff); // diff is negative here
    }

    // Toast feedback
    var msg = '';
    if(type === 'fast')      msg = '✅ Done! ' + Math.abs(diff) + 'min faster than planned 🚀';
    else if(type === 'slow') msg = '✅ Done! Took ' + diff + 'min longer than planned';
    else                     msg = '✅ Done! Right on time 👌';
    toast2(msg);
  }

  timerTaskIdx = -1;
  timerElapsed = 0;
  timerPaused = false;
  timerOvertimeMarked = false;

  updateDoneStats(); renderChecklist(); rTimeline();

  // Start break — user must manually start the next task after break ends
  var brk = parseInt(document.getElementById('s-brk').value) || 10;
  startBreak(brk, prevIdx, bar);
}

function startBreak(durationMin, prevTaskIdx, bar){
  stopBreak();
  // Find next task name to show in break banner
  var nextIdx = schedule.findIndex(function(s, i){ return i > prevTaskIdx && s.start >= 0 && !doneSet.has(s.taskId); });
  var nextName = nextIdx >= 0 ? schedule[nextIdx].name : null;

  // Skip break entirely if no break time set or no next task
  if(durationMin <= 0 || nextIdx < 0){
    document.getElementById('timerbar').classList.remove('on');
    if(nextIdx < 0) toast2('🎉 All tasks done for today!');
    return;
  }

  breakDur = durationMin * 60;
  breakRemaining = breakDur;
  bar.classList.add('on');
  bar.classList.add('break-mode');
  document.getElementById('tb-name').textContent = nextName
    ? '☕ Break — next up: ' + nextName
    : '☕ Break time';
  document.getElementById('tb-status').textContent = 'BREAK';
  document.getElementById('tb-status').style.background = 'var(--lbg)';
  document.getElementById('tb-status').style.color = 'var(--lo)';
  document.getElementById('tb-overtime').className = 'tb-overtime'; // hide
  document.getElementById('tb-pause-btn').textContent = '⏭ Skip Break';
  document.getElementById('tb-pause-btn').onclick = function(){ skipBreak(prevTaskIdx); };
  document.getElementById('tb-fill').className = 'tb-fill break';
  document.getElementById('tb-fill').style.width = '100%';
  updateBreakDisplay();
  breakInterval = setInterval(function(){ tickBreak(prevTaskIdx, nextName); }, 1000);
}

function tickBreak(prevTaskIdx, nextName){
  breakRemaining--;
  updateBreakDisplay();
  var pct = (breakRemaining / breakDur) * 100;
  document.getElementById('tb-fill').style.width = pct + '%';

  // Flash the clock in the last 5 seconds
  if(breakRemaining <= 5 && breakRemaining > 0){
    document.getElementById('timerbar').style.borderTopColor = breakRemaining % 2 === 0 ? 'var(--lo)' : 'var(--me)';
  }

  if(breakRemaining <= 0){
    stopBreak();
    document.getElementById('timerbar').style.borderTopColor = '';
    playBreakEndSound();
    sendNotif('🔔 Break over!', nextName ? 'Time to start: ' + nextName : 'Time to get back to work!');
    document.getElementById('timerbar').classList.remove('break-mode');
    document.getElementById('tb-name').textContent = nextName
      ? '🔔 Break over — ready for: ' + nextName
      : '🔔 Break over — start your next task!';
    document.getElementById('tb-clock').textContent = 'GO!';
    document.getElementById('tb-clock').className = 'tb-clock go';
    document.getElementById('tb-status').textContent = 'READY';
    document.getElementById('tb-status').style.background = 'var(--lbg)';
    document.getElementById('tb-status').style.color = 'var(--lo)';
    document.getElementById('tb-pause-btn').textContent = '⏸ Pause';
    document.getElementById('tb-pause-btn').onclick = pauseTimer;
    // Check if there are any tasks left
    var next = schedule.findIndex(function(s, i){ return i > prevTaskIdx && s.start >= 0 && !doneSet.has(s.taskId); });
    if(next < 0){
      document.getElementById('timerbar').classList.remove('on');
      toast2('🎉 All tasks done for today!');
    }
  }
}

function updateBreakDisplay(){
  var mm=Math.floor(breakRemaining/60), ss=breakRemaining%60;
  document.getElementById('tb-clock').textContent=(mm<10?'0':'')+mm+':'+(ss<10?'0':'')+ss;
  document.getElementById('tb-clock').className='tb-clock break';
}

function stopBreak(){
  if(breakInterval){clearInterval(breakInterval);breakInterval=null;}
}

function skipBreak(prevTaskIdx){
  stopBreak();
  document.getElementById('timerbar').classList.remove('break-mode');
  document.getElementById('timerbar').classList.remove('on');
  document.getElementById('tb-pause-btn').textContent='⏸ Pause';
  document.getElementById('tb-pause-btn').onclick=pauseTimer;
  toast2('⏭ Break skipped');
}

function playBreakEndSound(){
  try{
    var ctx=new(window.AudioContext||window.webkitAudioContext)();
    // Three gentle ascending bell tones
    [0, 0.35, 0.7].forEach(function(delay, i){
      var osc=ctx.createOscillator();
      var gain=ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type='sine';
      osc.frequency.value=880+i*110;
      gain.gain.setValueAtTime(0,ctx.currentTime+delay);
      gain.gain.linearRampToValueAtTime(0.4,ctx.currentTime+delay+0.05);
      gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+delay+0.8);
      osc.start(ctx.currentTime+delay);
      osc.stop(ctx.currentTime+delay+0.85);
    });
  }catch(e){}
}

function skipTimer(){
  stopTimer(); stopBreak();
  document.getElementById('timerbar').classList.remove('on');
  document.getElementById('timerbar').classList.remove('break-mode');
  document.getElementById('tb-pause-btn').textContent='⏸ Pause';
  document.getElementById('tb-pause-btn').onclick=pauseTimer;
  timerPaused=false;
  timerTaskIdx=-1;
  toast2('⏭ Task skipped');
}

// ── Performance log ──
function recordPerf(schedItem, actualMin, diffMin, type){
  var taskObj=null;
  for(var i=0;i<tasks.length;i++){if(tasks[i].id===schedItem.taskId){taskObj=tasks[i];break;}}
  perfLog.push({
    taskId:schedItem.taskId,
    name:schedItem.name,
    estimated:schedItem.dur,
    actual:actualMin,
    diff:diffMin,
    type:type, // 'fast','slow','on','over'
    time:new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
  });
  // Update the task's average actual time for future scheduling
  if(taskObj){
    if(!taskObj.avgActual) taskObj.avgActual=actualMin;
    else taskObj.avgActual=Math.round((taskObj.avgActual+actualMin)/2);
  }
  renderPerfLog();
}

function renderPerfLog(){
  var el = document.getElementById('perf-list');
  if(!el) return;
  if(!perfLog.length){
    el.innerHTML = '<div style="color:var(--mu);font-size:12px;padding:10px 0;text-align:center">No tasks tracked yet — generate a schedule, hit <strong>▶ Start Day</strong>, and complete tasks to see timing data here.</div>';
    return;
  }
  // Summary row
  var fast  = perfLog.filter(function(p){return p.type==='fast';}).length;
  var slow  = perfLog.filter(function(p){return p.type==='slow'||p.type==='over';}).length;
  var onT   = perfLog.filter(function(p){return p.type==='on';}).length;
  var totalSaved = perfLog.filter(function(p){return p.type==='fast';}).reduce(function(s,p){return s+Math.abs(p.diff);},0);
  var totalOver  = perfLog.filter(function(p){return p.type==='slow'||p.type==='over';}).reduce(function(s,p){return s+p.diff;},0);
  var summaryHtml = '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;padding:8px 10px;background:var(--s2);border-radius:var(--rs)">'
    +(fast  ? '<span style="color:var(--lo);font-weight:700;font-size:12px">🚀 '+fast+' faster (saved '+totalSaved+'min)</span>' : '')
    +(onT   ? '<span style="color:var(--ac);font-weight:700;font-size:12px">✅ '+onT+' on time</span>' : '')
    +(slow  ? '<span style="color:var(--hi);font-weight:700;font-size:12px">🐢 '+slow+' over (+'+totalOver+'min)</span>' : '')
    +'</div>';
  el.innerHTML = summaryHtml + perfLog.map(function(p){
    var icon  = p.type==='fast'?'🚀':p.type==='slow'?'🐢':p.type==='over'?'⏰':'✅';
    var col   = p.type==='fast'?'var(--lo)':(p.type==='on'?'var(--ac)':'var(--hi)');
    var diffTxt = p.type==='fast'
      ? Math.abs(p.diff)+'min faster'
      : p.type==='on'
      ? 'on time'
      : '+'+Math.abs(p.diff)+'min over';
    return '<div style="display:flex;align-items:center;gap:10px;padding:8px 11px;background:var(--bg);border:1.5px solid var(--bdr);border-radius:var(--rs);margin-bottom:5px">'
      +'<span style="font-size:16px">'+icon+'</span>'
      +'<div style="flex:1">'
      +'<div style="font-weight:700;font-size:12px">'+esc(p.name)+'</div>'
      +'<div style="font-size:10px;color:var(--mu)">Estimated '+p.estimated+'min · Actual '+p.actual+'min · '+p.time+'</div>'
      +'</div>'
      +'<div style="font-size:11px;font-weight:700;color:'+col+'">'+diffTxt+'</div>'
      +'</div>';
  }).join('');
}

