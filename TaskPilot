  tasks.push({id:Date.now(),name:name,dur:dur,dead:dead,pri:selPriVal});
  document.getElementById('t-name').value='';
  document.getElementById('t-dur').value='';
  document.getElementById('t-dead').value='';
  persist(); rTasks(); uSum(); toast2('✅ Task added');
}
function delTask(id){ tasks=tasks.filter(function(t){return t.id!==id;}); persist(); rTasks(); uSum(); }
function rTasks(){
  var el=document.getElementById('task-list');
  if(!tasks.length){el.innerHTML='';return;}
  var pc={high:'var(--hi)',med:'var(--me)',low:'var(--lo)'};
  el.innerHTML=tasks.map(function(t){
    return '<div class="titem"><div class="dot" style="background:'+pc[t.pri]+';margin-top:3px"></div><div class="ti"><div class="tn">'+esc(t.name)+'</div><div class="tm">'+t.dur+'min · '+t.pri+(t.dead?' · Due '+t.dead:'')+'</div></div><button class="xbtn" onclick="delTask('+t.id+')">✕</button></div>';
  }).join('');
}
function uSum(){
  var h=tasks.filter(function(t){return t.pri==='high';}).length;
  var tot=tasks.reduce(function(s,t){return s+t.dur;},0);
  document.getElementById('gen-sum').textContent=tasks.length
    ? tasks.length+' task'+(tasks.length>1?'s':'')+' · '+(Math.floor(tot/60)?Math.floor(tot/60)+'h ':'')+''+(tot%60?tot%60+'min':'')+' · '+h+' high-pri'
    : 'Add tasks above then generate your schedule.';
}
function esc(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

