<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TaskPilot</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#F7F5F0;--surf:#fff;--s2:#F0EDE5;--bdr:#E4DDD3;
  --tx:#1C1916;--mu:#857E77;
  --ac:#3B6FD4;--acl:#EBF0FB;--ac2:#E8652A;
  --hi:#D63B3B;--hbg:#FCEAEA;
  --me:#E8952A;--mbg:#FEF4E6;
  --lo:#3BAD72;--lbg:#E8F7EE;
  --te:#7C3AED;--tbg:#F3EFFE;
  --co:#0EA5E9;--cbg:#E0F2FE;
  --r:14px;--rs:9px;
  --sh:0 2px 14px rgba(28,25,22,.07);
  --shm:0 5px 24px rgba(28,25,22,.10);
  --shl:0 14px 44px rgba(28,25,22,.14);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;font-size:14px;overflow-x:hidden;}
body.xmas{--bg:#EEF7EF;--ac:#B22222;--acl:#FDEAEA;}
body.cny{--bg:#FFF8EE;--ac:#C0392B;--acl:#FFF0D5;}
body.ny{--bg:#060614;--surf:#0D0D22;--s2:#131330;--bdr:#1E1E42;--tx:#EEEEFF;--mu:#6060A0;}

/* WELCOME */
#ws{position:fixed;inset:0;z-index:2000;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#FF6B35 0%,#F7931E 15%,#FFD700 30%,#FF8C42 48%,#C0392B 65%,#8B1A8B 82%,#4A1D6B 100%);padding:20px;}
.wp{position:absolute;inset:0;overflow:hidden;pointer-events:none;}
.wp span{position:absolute;border-radius:50%;background:rgba(255,255,255,.09);animation:fup linear infinite;}
@keyframes fup{0%{transform:translateY(100vh) scale(0);opacity:0}8%{opacity:1}92%{opacity:.3}100%{transform:translateY(-80px) scale(1);opacity:0}}
.wcard{position:relative;z-index:2;max-width:480px;width:100%;background:rgba(255,255,255,.13);backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,.3);border-radius:26px;padding:48px 42px;text-align:center;box-shadow:0 28px 72px rgba(0,0,0,.32);animation:cup .8s cubic-bezier(.2,.8,.2,1) .1s both;}
@keyframes cup{from{transform:translateY(36px);opacity:0}to{transform:none;opacity:1}}
.wlogo{font-family:'Playfair Display',serif;font-size:clamp(30px,8vw,52px);font-weight:900;background:linear-gradient(135deg,#fff 0%,#C8DCFF 38%,#68B4FF 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1.1;margin-bottom:8px;filter:drop-shadow(0 2px 14px rgba(58,155,255,.5));}
.wsub{font-size:14px;color:rgba(255,255,255,.88);margin-bottom:3px;}
.wmade{font-size:12px;color:rgba(255,255,255,.5);margin-bottom:30px;font-style:italic;}
.wbtn{display:inline-flex;align-items:center;gap:9px;padding:13px 34px;border-radius:100px;background:#fff;color:#1C1916;font-family:'Outfit',sans-serif;font-size:15px;font-weight:700;border:none;cursor:pointer;box-shadow:0 8px 28px rgba(0,0,0,.22);transition:all .25s;}
.wbtn:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 16px 44px rgba(0,0,0,.3);}
.warr{transition:transform .2s;}
.wbtn:hover .warr{transform:translateX(5px);}
.wfs{display:flex;gap:8px;justify-content:center;margin-top:22px;flex-wrap:wrap;}
.wf{font-size:10px;color:rgba(255,255,255,.68);background:rgba(255,255,255,.11);border:1px solid rgba(255,255,255,.2);padding:4px 10px;border-radius:20px;}

/* HOLIDAY */
.hov{position:fixed;inset:0;pointer-events:none;z-index:499;overflow:hidden;}
.sf{position:absolute;top:-24px;animation:sfll linear infinite;}
@keyframes sfll{0%{transform:translateY(-24px) rotate(0)}100%{transform:translateY(105vh) rotate(400deg);opacity:0}}
.ln{position:absolute;top:-10px;animation:swy ease-in-out infinite;}
@keyframes swy{0%,100%{transform:rotate(-9deg)}50%{transform:rotate(9deg)}}
.fw{position:absolute;width:5px;height:5px;border-radius:50%;animation:bst .8s ease-out forwards;}
@keyframes bst{0%{transform:scale(0);opacity:1}100%{transform:scale(20);opacity:0}}
.hbadge{position:fixed;top:68px;left:50%;transform:translateX(-50%);font-size:11px;padding:4px 14px;border-radius:20px;pointer-events:none;white-space:nowrap;z-index:600;font-weight:700;}

/* NAV */
#app{display:none;}
nav{position:sticky;top:0;z-index:100;height:54px;background:rgba(247,245,240,.94);backdrop-filter:blur(16px);border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;padding:0 18px;}
body.ny nav{background:rgba(6,6,20,.94);}
.nlogo{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--ac);}
.nlogo em{color:var(--ac2);font-style:normal;}
.ntabs{display:flex;gap:2px;overflow-x:auto;scrollbar-width:none;}
.ntabs::-webkit-scrollbar{display:none;}
.nt{padding:5px 11px;border-radius:20px;border:none;background:transparent;color:var(--mu);font-family:'Outfit',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap;}
.nt.on{background:var(--ac);color:#fff;}
.nt:hover:not(.on){background:var(--s2);color:var(--tx);}

/* LAYOUT */
.pg{max-width:1160px;margin:0 auto;padding:20px 14px;}
.view{display:none;}
.view.on{display:block;animation:fin .28s ease;}
@keyframes fin{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}

/* CARDS */
.card{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:18px;box-shadow:var(--sh);}
.ctitle{font-family:'Playfair Display',serif;font-size:15px;margin-bottom:13px;display:flex;align-items:center;gap:6px;}
.field{margin-bottom:11px;}
label{display:block;font-size:10px;font-weight:700;color:var(--mu);text-transform:uppercase;letter-spacing:.7px;margin-bottom:4px;}
input[type=text],input[type=number],input[type=date],input[type=time],select,textarea{width:100%;padding:8px 11px;border:1.5px solid var(--bdr);border-radius:var(--rs);background:var(--bg);font-family:'Outfit',sans-serif;font-size:13px;color:var(--tx);outline:none;transition:border-color .18s;}
input:focus,select:focus,textarea:focus{border-color:var(--ac);}
textarea{resize:vertical;min-height:80px;line-height:1.6;}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
@media(max-width:720px){.g2{grid-template-columns:1fr}}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 15px;border-radius:100px;border:none;font-family:'Outfit',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .18s;white-space:nowrap;}
.bp{background:var(--ac);color:#fff;}
.bp:hover{filter:brightness(1.1);transform:translateY(-1px);}
.bs{background:var(--s2);color:var(--tx);}
.bs:hover{background:var(--bdr);}
.bd{background:var(--hbg);color:var(--hi);}
.bg{background:var(--lbg);color:var(--lo);}
.bw{background:#fff;color:var(--ac);font-weight:700;}
.bw:hover{background:#f0f4ff;}
.bf{width:100%;justify-content:center;}
.bsm{padding:5px 11px;font-size:11px;}
.blg{padding:11px 22px;font-size:14px;}

/* PRIORITY PICKER */
.prow{display:flex;gap:5px;}
.pb{flex:1;padding:7px;border-radius:var(--rs);border:1.5px solid var(--bdr);background:var(--bg);font-family:'Outfit',sans-serif;font-size:11px;font-weight:700;cursor:pointer;transition:all .14s;text-align:center;}
.pb[data-p=low].on{background:var(--lbg);border-color:var(--lo);color:#1e6b40;}
.pb[data-p=med].on{background:var(--mbg);border-color:var(--me);color:#8b5010;}
.pb[data-p=high].on{background:var(--hbg);border-color:var(--hi);color:var(--hi);}

/* DAY PICKER */
.drow{display:flex;gap:4px;flex-wrap:wrap;}
.db{flex:1;min-width:32px;padding:5px 2px;border-radius:8px;border:1.5px solid var(--bdr);background:var(--bg);font-family:'Outfit',sans-serif;font-size:10px;font-weight:800;cursor:pointer;transition:all .14s;text-align:center;color:var(--mu);}
.db.on{background:var(--ac);border-color:var(--ac);color:#fff;}
.db:hover:not(.on){border-color:var(--ac);color:var(--ac);}
.pchips{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px;}
.pc{padding:3px 9px;border-radius:20px;border:1.5px solid var(--bdr);background:var(--s2);font-size:10px;font-weight:700;color:var(--mu);cursor:pointer;transition:all .14s;}
.pc:hover{border-color:var(--ac);color:var(--ac);background:var(--acl);}

/* COLOR PICKER */
.crow{display:flex;gap:6px;flex-wrap:wrap;}
.cb{width:22px;height:22px;border-radius:50%;border:3px solid transparent;cursor:pointer;transition:transform .14s,border-color .14s;}
.cb.on{border-color:var(--tx);transform:scale(1.18);}

/* GEN BAR */
.genbar{margin-top:18px;padding:15px 18px;background:linear-gradient(135deg,var(--ac) 0%,#5B8FEE 100%);border-radius:var(--r);color:#fff;display:flex;align-items:center;justify-content:space-between;gap:12px;box-shadow:0 7px 24px rgba(59,111,212,.28);}
@media(max-width:520px){.genbar{flex-direction:column;text-align:center}}
.genbar h3{font-family:'Playfair Display',serif;font-size:16px;margin-bottom:1px;}
.genbar p{font-size:11px;opacity:.85;}

/* NO SCHOOL BTN */
.nsbtn{display:flex;align-items:center;gap:7px;padding:10px 14px;border-radius:var(--rs);border:1.5px dashed var(--me);background:var(--mbg);font-family:'Outfit',sans-serif;font-size:12px;font-weight:700;color:#8b5010;cursor:pointer;transition:all .18s;width:100%;justify-content:center;margin-top:9px;}
.nsbtn:hover{background:#fde8c4;border-style:solid;}
.nsbtn.on{background:var(--lbg);border-color:var(--lo);color:#1e6b40;border-style:solid;}

/* LISTS */
.tlist,.blist{display:flex;flex-direction:column;gap:6px;margin-top:11px;}
.titem,.bitem{display:flex;align-items:flex-start;gap:8px;padding:9px 11px;background:var(--bg);border:1.5px solid var(--bdr);border-radius:var(--rs);transition:box-shadow .18s;}
.titem:hover,.bitem:hover{box-shadow:var(--sh);}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.ti{flex:1;min-width:0;}
.tn{font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tm{font-size:10px;color:var(--mu);margin-top:1px;line-height:1.5;}
.xbtn{background:none;border:none;cursor:pointer;color:var(--mu);font-size:14px;padding:2px;opacity:.45;transition:opacity .14s;flex-shrink:0;}
.xbtn:hover{opacity:1;color:var(--hi);}
.dchips{display:flex;gap:3px;flex-wrap:wrap;margin-top:2px;}
.dchip{font-size:9px;font-weight:800;padding:1px 5px;border-radius:3px;background:var(--acl);color:var(--ac);}

/* OCR */
.ozone{border:2px dashed var(--bdr);border-radius:var(--r);padding:22px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg);position:relative;}
.ozone:hover,.ozone.dov{border-color:var(--ac);background:var(--acl);}
.ozone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.obar-w{height:4px;background:var(--bdr);border-radius:2px;margin-top:9px;overflow:hidden;display:none;}
.obar{height:100%;background:var(--ac);border-radius:2px;transition:width .3s;width:0%;}

/* DASHBOARD */
.dhdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;gap:10px;flex-wrap:wrap;}
.dtitle{font-family:'Playfair Display',serif;font-size:22px;}
.ddate{font-size:12px;color:var(--mu);margin-top:1px;}
.dacts{display:flex;gap:5px;flex-wrap:wrap;}
.srow{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;}
@media(max-width:580px){.srow{grid-template-columns:repeat(2,1fr)}}
.sc{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:12px 14px;box-shadow:var(--sh);}
.sl{font-size:9px;font-weight:800;color:var(--mu);text-transform:uppercase;letter-spacing:.7px;margin-bottom:3px;}
.sv{font-family:'Playfair Display',serif;font-size:26px;line-height:1;}
.ss{font-size:10px;color:var(--mu);margin-top:2px;}
.srng{display:flex;align-items:center;gap:9px;margin-top:2px;}
.ring{width:46px;height:46px;}
.rtrk{fill:none;stroke:var(--s2);stroke-width:6;}
.rfil{fill:none;stroke:var(--ac);stroke-width:6;stroke-linecap:round;stroke-dasharray:119;stroke-dashoffset:119;transform-origin:center;transform:rotate(-90deg);transition:stroke-dashoffset 1.1s cubic-bezier(.4,0,.2,1);}
.vtog{display:flex;gap:3px;background:var(--s2);border-radius:24px;padding:3px;width:fit-content;margin-bottom:13px;}
.vb{padding:5px 13px;border-radius:20px;border:none;background:transparent;color:var(--mu);font-family:'Outfit',sans-serif;font-size:11px;font-weight:700;cursor:pointer;transition:all .18s;}
.vb.on{background:var(--surf);color:var(--tx);box-shadow:var(--sh);}

/* TIMELINE */
.tlwrap{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh);}
.tlin{overflow-y:auto;max-height:490px;}
.tlhr{display:flex;border-bottom:1px solid var(--bdr);min-height:56px;}
.tlhr:last-child{border-bottom:none;}
.tllbl{width:56px;flex-shrink:0;padding:8px 9px;font-size:10px;font-weight:700;color:var(--mu);border-right:1px solid var(--bdr);display:flex;align-items:flex-start;padding-top:8px;}
.tlct{flex:1;padding:4px 7px;display:flex;flex-direction:column;gap:3px;}
.sb{border-radius:7px;padding:6px 9px;font-size:11px;cursor:grab;user-select:none;transition:transform .14s,box-shadow .14s;}
.sb:hover{transform:translateY(-1px);box-shadow:var(--shm);}
.sb.dragging{opacity:.6;cursor:grabbing;transform:scale(1.02);}
.sbn{font-weight:700;}
.sbt{font-size:9px;opacity:.7;margin-top:1px;}
.sbtg{display:inline-block;font-size:8px;font-weight:800;padding:1px 5px;border-radius:3px;margin-top:2px;text-transform:uppercase;letter-spacing:.4px;}
.s-high{background:var(--hbg);border-left:3px solid var(--hi);color:#7a1a1a;}
.s-med{background:var(--mbg);border-left:3px solid var(--me);color:#7a4010;}
.s-low{background:var(--lbg);border-left:3px solid var(--lo);color:#1a5c35;}
.s-busy{background:var(--s2);border:1.5px dashed var(--bdr);color:var(--mu);font-style:italic;font-size:10px;}
.tlhr.dov .tlct{background:var(--acl);border-radius:5px;}

/* CAL */
.calwrap{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh);}
.calhdr{padding:12px 16px;border-bottom:1px solid var(--bdr);background:var(--s2);display:flex;align-items:center;justify-content:space-between;}
.calbdy{overflow-y:auto;max-height:490px;}
.ctr{display:flex;border-bottom:1px solid var(--bdr);min-height:50px;}
.ctlbl{width:56px;flex-shrink:0;font-size:10px;color:var(--mu);font-weight:700;padding:6px 9px;border-right:1px solid var(--bdr);}
.ctcell{flex:1;padding:3px 6px;}
.cev{border-radius:6px;padding:5px 8px;margin-bottom:2px;font-size:11px;font-weight:600;}

/* DASH BOTTOM */
.dbot{display:grid;grid-template-columns:1fr 270px;gap:14px;margin-top:14px;}
@media(max-width:780px){.dbot{grid-template-columns:1fr}}
.tplist{display:flex;flex-direction:column;gap:6px;}
.tpi{display:flex;align-items:center;gap:7px;padding:8px 11px;background:var(--surf);border:1px solid var(--bdr);border-radius:var(--rs);cursor:pointer;transition:all .18s;box-shadow:var(--sh);}
.tpi:hover{border-color:var(--ac);}
.tpi.dn{opacity:.5;}
.tpck{width:17px;height:17px;border-radius:50%;border:2px solid var(--bdr);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .18s;}
.tpi.dn .tpck{background:var(--ac);border-color:var(--ac);color:#fff;}
.tpn{flex:1;font-size:12px;font-weight:500;}
.tpi.dn .tpn{text-decoration:line-through;}
.pgw{height:4px;background:var(--s2);border-radius:2px;overflow:hidden;margin:7px 0;}
.pgf{height:100%;background:linear-gradient(90deg,var(--ac),#7BA8F0);border-radius:2px;transition:width 1s cubic-bezier(.4,0,.2,1);}
.tipc{padding:8px 10px;background:var(--s2);border-radius:var(--rs);font-size:11px;line-height:1.6;}

/* TIMETABLE */
.tt{overflow-x:auto;}
.ttg{display:grid;grid-template-columns:48px repeat(7,1fr);min-width:420px;}
.tth{padding:6px 3px;text-align:center;font-weight:800;font-size:9px;color:var(--mu);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--bdr);background:var(--s2);}
.tttm{height:40px;font-size:9px;color:var(--mu);font-weight:700;padding:5px 6px 0;text-align:right;border-right:1px solid var(--bdr);border-bottom:1px solid var(--bdr);}
.ttc{height:40px;border-right:1px solid var(--bdr);border-bottom:1px solid var(--bdr);position:relative;}
.ttc:last-child{border-right:none;}
.tte{position:absolute;left:1px;right:1px;border-radius:4px;padding:2px 4px;font-size:9px;font-weight:800;color:#fff;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;box-shadow:0 1px 3px rgba(0,0,0,.15);z-index:2;}
.clsr{display:flex;align-items:center;gap:8px;padding:8px 11px;background:var(--bg);border:1.5px solid var(--bdr);border-radius:var(--rs);}
.clsb{width:3px;height:30px;border-radius:2px;flex-shrink:0;}
.clsi{flex:1;min-width:0;}
.clsn{font-weight:700;font-size:12px;}
.clsm{font-size:10px;color:var(--mu);}
.clsdc{display:flex;gap:3px;margin-top:2px;}
.cdd{font-size:8px;font-weight:900;padding:2px 4px;border-radius:3px;color:#fff;}

/* TESTS */
.ecard{display:flex;align-items:flex-start;gap:10px;padding:11px 13px;background:var(--surf);border:1px solid var(--bdr);border-radius:var(--rs);box-shadow:var(--sh);}
.ecard:hover{border-color:var(--ac);}
.etype-icon{font-size:20px;flex-shrink:0;}
.einfo{flex:1;min-width:0;}
.ename{font-weight:700;font-size:13px;}
.emeta{font-size:10px;color:var(--mu);margin-top:1px;}
.ebadge{font-size:9px;font-weight:800;padding:2px 8px;border-radius:20px;}
.cdown{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;line-height:1;}
.cdlbl{font-size:10px;color:var(--mu);}
.c-urgent{color:var(--hi);}
.c-soon{color:var(--me);}
.c-ok{color:var(--lo);}

/* TIMER BAR */
#timerbar{position:fixed;bottom:0;left:0;right:0;z-index:800;background:var(--surf);border-top:2px solid var(--ac);padding:10px 16px;display:none;align-items:center;gap:10px;flex-wrap:wrap;box-shadow:0 -4px 24px rgba(59,111,212,.15);}
#timerbar.on{display:flex;}
#timerbar.break-mode{border-top-color:var(--lo);background:#f0fdf4;}
body.ny #timerbar{background:var(--surf);}
.tb-name{font-weight:700;font-size:13px;flex:1;min-width:100px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tb-clock{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:var(--ac);min-width:82px;text-align:center;letter-spacing:1px;}
.tb-clock.over{color:var(--hi);}
.tb-clock.paused{color:var(--me);opacity:.7;}
.tb-clock.break{color:var(--lo);}
.tb-clock.go{color:var(--lo);animation:goPulse .6s ease-in-out infinite;}
@keyframes goPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.08);}}
.tb-prog{flex:2;min-width:90px;height:6px;background:var(--s2);border-radius:3px;overflow:hidden;}
.tb-fill{height:100%;background:linear-gradient(90deg,var(--ac),#7BA8F0);border-radius:3px;transition:width .5s;}
.tb-fill.over{background:linear-gradient(90deg,var(--hi),#FF8B8B);}
.tb-fill.break{background:linear-gradient(90deg,var(--lo),#6EE7B7);}
.tb-status{font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;white-space:nowrap;}
.tb-overtime{font-size:11px;font-weight:700;color:var(--hi);background:var(--hbg);padding:3px 9px;border-radius:20px;white-space:nowrap;display:none;}
.tb-overtime.show{display:block;}

/* REVIEW */
.rev-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
@media(max-width:680px){.rev-grid{grid-template-columns:1fr}}
.mood-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:4px;}
.mood-btn{font-size:22px;padding:6px;border-radius:var(--rs);border:2px solid var(--bdr);background:var(--bg);cursor:pointer;transition:all .14s;}
